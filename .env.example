# Copia este archivo a `.env` en la raíz del repo.
# `api-log-guard` y `scripts/run_logguard_workers.py` leen este `.env` raíz.
# Next.js también puede leer `API_GATEWAY_URL` desde aquí en desarrollo local.

# --------------------------------------------------
# Frontend / proxy de Next
# --------------------------------------------------

# URL base del api-log-guard SIN barra final.
API_GATEWAY_URL=http://localhost:4000

# Compatibilidad heredada. El proxy aún la revisa, pero la opción recomendada es API_GATEWAY_URL.
# NEXT_PUBLIC_API_URL=http://localhost:4000

# --------------------------------------------------
# Gateway API (services/api-log-guard)
# --------------------------------------------------

PORT=4000
MONGODB_URL=mongodb://admin:logguard123@localhost:27017/logguard?authSource=admin

# Si usas el pipeline Python sin tocar código, deja este valor en `logguard`:
# analytics-engine escribe sobre esa base de datos de forma fija.
MONGODB_DB_NAME=logguard

CORS_ORIGIN=http://localhost:3000

# Nota: el gateway actual no usa RabbitMQ.
# ENABLE_RABBITMQ=false

# --------------------------------------------------
# Pipeline opcional (analytics-engine + ingestion-service)
# --------------------------------------------------

RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Si defines una carpeta local con CSV, ingestion-service no llamará a Kaggle.
LOCAL_DATASET_PATH=

KAGGLE_DATASET=bertvankeulen/cicids-2017
KAGGLE_API_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=

STREAM_INTERVAL_MS=500
MAX_STREAM_ROWS=
SAMPLE_ROWS_PER_CSV=

# Reservadas por la configuración actual; hoy no activan lógica útil por sí solas.
MODEL_PATH=/app/model
DATA_PATH=/app/data
