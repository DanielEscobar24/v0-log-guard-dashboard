# Copia a `.env.local` para desarrollo local.
# En Vercel: Project → Settings → Environment Variables (Production / Preview).

# URL privada/servidor del api-log-guard SIN barra final.
# Next la usa desde el proxy `/api/*`, así el navegador nunca ve esta URL.
# Desarrollo local:
API_GATEWAY_URL=http://localhost:4000

# Producción (ejemplo; usa la URL real de tu gateway desplegado):
# API_GATEWAY_URL=https://tu-api-log-guard.ejemplo.com

# Compatibilidad heredada. Ya no es necesaria si usas el proxy de Next.
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Si vas a consumir el gateway directamente desde el navegador, el backend debe tener
# CORS_ORIGIN con tu URL de Vercel (https://....vercel.app o dominio custom).

# --------------------------------------------------
# Backend API (services/api-log-guard)
# --------------------------------------------------

# Puerto local del backend.
PORT=4000

# Conexion a MongoDB Atlas o a tu instancia local.
MONGODB_URL=mongodb://admin:logguard123@localhost:27017/logguard?authSource=admin

# Base de datos a usar dentro de Mongo.
MONGODB_DB_NAME=logguard

# URL del frontend permitida por CORS.
CORS_ORIGIN=http://localhost:3000

# Por defecto dejamos RabbitMQ apagado para usar la API solo contra Mongo.
ENABLE_RABBITMQ=false

# Solo hace falta si ENABLE_RABBITMQ=true
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
